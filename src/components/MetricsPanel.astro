---
---

<div class="metrics-container">
  <div class="framework-badge badge-angular">
    <svg width="12" height="12" viewBox="0 0 256 272">
      <path fill="#DD0031" d="M.1 45.522L125.908.697l129.196 44.028l-20.919 166.45l-108.277 59.966l-106.583-59.169z"/>
      <path fill="#C3002F" d="M255.104 44.725L125.908.697v270.444l108.277-59.866z"/>
      <path fill="#FFF" d="M125.908 32.432L63.597 169.081l23.264.001l12.56-31.372h52.988l12.56 31.371h23.264zm.001 55.488l18.159 44.34h-36.318z"/>
    </svg>
    Metrics
  </div>

  <div class="stats-grid">
    <div class="stat-card stat-card-clickable" id="stat-fps" title="Click for performance details">
      <span class="stat-value" id="fps-value">0</span>
      <span class="stat-label">FPS</span>
    </div>
    <div class="stat-card">
      <span class="stat-value" id="frame-time">0</span>
      <span class="stat-label">Frame Time</span>
    </div>
    <div class="stat-card">
      <span class="stat-value" id="particle-count">0</span>
      <span class="stat-label">Particles</span>
    </div>
  </div>

  <div class="chart-section">
    <span class="chart-title">FPS History</span>
    <canvas id="fps-chart" class="sparkline-canvas"></canvas>
  </div>

  <div class="uptime-bar">
    <span class="uptime-icon">&#9201;</span>
    <span class="uptime-label">Uptime</span>
    <span class="uptime-value" id="uptime-value">0:00</span>
  </div>

  <div class="auto-reduce-bar">
    <span class="auto-reduce-label">Auto-reduce</span>
    <button id="auto-reduce-toggle" class="auto-reduce-toggle" aria-label="Toggle auto-reduce particles" title="Gradually reduces particles when FPS drops below 45">
      <span class="auto-reduce-knob"></span>
    </button>
  </div>

  <div class="force-low-fps-bar">
    <span class="force-low-fps-label">Force low FPS</span>
    <button id="force-low-fps-toggle" class="auto-reduce-toggle" aria-label="Toggle force low FPS" title="Experimental: caps reported FPS to 15 for testing">
      <span class="auto-reduce-knob"></span>
    </button>
  </div>

  <div class="status-bar">
    <div class="status-dot" id="status-dot"></div>
    <span class="status-text" id="status-text">Initializing...</span>
  </div>
</div>

<script>
  import { $particleMetrics, $isPaused, $resetTrigger, $autoReduceParticles, $forceLowFps } from '../stores/store';

  function drawSparkline(
    canvas: HTMLCanvasElement,
    data: number[],
    color: string,
    minVal?: number,
    maxVal?: number,
  ) {
    if (data.length < 2) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * window.devicePixelRatio;
    canvas.height = rect.height * window.devicePixelRatio;
    ctx.scale(window.devicePixelRatio, window.devicePixelRatio);

    const w = rect.width;
    const h = rect.height;
    const padding = 2;

    ctx.clearRect(0, 0, w, h);

    const min = minVal ?? Math.min(...data);
    const max = maxVal ?? Math.max(...data);
    const range = max - min || 1;

    // Filled area
    ctx.beginPath();
    ctx.moveTo(padding, h - padding);
    for (let i = 0; i < data.length; i++) {
      const x = padding + (i / (data.length - 1)) * (w - 2 * padding);
      const y = h - padding - ((data[i] - min) / range) * (h - 2 * padding);
      ctx.lineTo(x, y);
    }
    ctx.lineTo(w - padding, h - padding);
    ctx.closePath();

    const gradient = ctx.createLinearGradient(0, 0, 0, h);
    gradient.addColorStop(0, color + '30');
    gradient.addColorStop(1, color + '05');
    ctx.fillStyle = gradient;
    ctx.fill();

    // Line
    ctx.beginPath();
    for (let i = 0; i < data.length; i++) {
      const x = padding + (i / (data.length - 1)) * (w - 2 * padding);
      const y = h - padding - ((data[i] - min) / range) * (h - 2 * padding);
      if (i === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    }
    ctx.strokeStyle = color;
    ctx.lineWidth = 1.5;
    ctx.stroke();
  }

  function formatUptime(seconds: number): string {
    const m = Math.floor(seconds / 60);
    const s = seconds % 60;
    return `${m}:${s.toString().padStart(2, '0')}`;
  }

  const fpsValue = document.getElementById('fps-value')!;
  const frameTime = document.getElementById('frame-time')!;
  const particleCount = document.getElementById('particle-count')!;
  const fpsChart = document.getElementById('fps-chart') as HTMLCanvasElement;
  const statFps = document.getElementById('stat-fps')!;
  const statusDot = document.getElementById('status-dot')!;
  const statusText = document.getElementById('status-text')!;
  const uptimeValue = document.getElementById('uptime-value')!;

  // Click FPS card to open performance popup
  statFps.addEventListener('click', () => {
    if ((window as any).__showPerfPopup) {
      (window as any).__showPerfPopup();
    }
  });

  // Auto-reduce toggle
  const autoReduceToggle = document.getElementById('auto-reduce-toggle')!;

  function syncAutoReduceUI() {
    autoReduceToggle.classList.toggle('active', $autoReduceParticles.get());
  }

  syncAutoReduceUI();

  autoReduceToggle.addEventListener('click', () => {
    $autoReduceParticles.set(!$autoReduceParticles.get());
    syncAutoReduceUI();
  });

  $autoReduceParticles.subscribe(() => {
    syncAutoReduceUI();
  });

  // Force low FPS toggle
  const forceLowFpsToggle = document.getElementById('force-low-fps-toggle')!;

  function syncForceLowFpsUI() {
    forceLowFpsToggle.classList.toggle('active', $forceLowFps.get());
  }

  syncForceLowFpsUI();

  forceLowFpsToggle.addEventListener('click', () => {
    $forceLowFps.set(!$forceLowFps.get());
    syncForceLowFpsUI();
  });

  // Uptime counter — counts while not paused, resets on particle reset
  let uptimeSeconds = 0;
  setInterval(() => {
    if (!$isPaused.get()) {
      uptimeSeconds++;
      uptimeValue.textContent = formatUptime(uptimeSeconds);
    }
  }, 1000);

  $resetTrigger.subscribe(() => {
    uptimeSeconds = 0;
    uptimeValue.textContent = formatUptime(0);
  });

  $particleMetrics.subscribe((m) => {
    fpsValue.textContent = String(m.fps);
    particleCount.textContent = String(m.particleCount);

    // Frame time
    const ft = m.fps > 0 ? (1000 / m.fps).toFixed(1) : '0';
    frameTime.textContent = `${ft}ms`;

    // FPS color
    const fpsColor = m.fps >= 55 ? '#22c55e' : m.fps >= 30 ? '#f59e0b' : '#ef4444';
    fpsValue.style.color = fpsColor;

    // Highlight card
    statFps.classList.toggle('highlight', m.fps >= 55);

    // Status
    statusDot.style.background = fpsColor;
    const autoReduce = $autoReduceParticles.get();
    if (m.fps >= 55) {
      statusText.textContent = autoReduce ? 'Running optimally — auto-reduce on' : 'System running optimally';
    } else if (m.fps >= 30) {
      statusText.textContent = autoReduce ? 'Auto-reducing particles...' : 'Performance degraded';
    } else {
      statusText.textContent = autoReduce ? 'Auto-reducing particles...' : 'Low performance — enable auto-reduce';
    }

    // Sparkline
    drawSparkline(fpsChart, m.fpsHistory, '#dd0031', 0, 80);
  });
</script>

<style>
  .metrics-container {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    height: 100%;
    overflow-y: auto;
    overflow-x: hidden;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
  }

  .stat-card {
    background: var(--surface-subtle);
    border: 1px solid var(--surface-border);
    border-radius: 8px;
    padding: 8px 10px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    transition: all 0.3s;
  }

  .stat-card-clickable {
    cursor: pointer;
  }

  .stat-card-clickable:hover {
    background: var(--surface-overlay-hover);
    border-color: var(--border-color);
  }

  .stat-card.highlight {
    border-color: rgba(34, 197, 94, 0.3);
    background: rgba(34, 197, 94, 0.05);
  }

  .stat-card.highlight.stat-card-clickable:hover {
    background: rgba(34, 197, 94, 0.1);
  }

  .stat-value {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-primary);
    font-family: 'Courier New', monospace;
  }

  .stat-label {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
  }

  .chart-section {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .chart-title {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
  }

  .sparkline-canvas {
    width: 100%;
    height: 40px;
    border-radius: 6px;
    background: var(--surface-subtle);
  }

  .uptime-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    background: var(--surface-subtle);
    border: 1px solid var(--surface-border);
    border-radius: 8px;
  }

  .uptime-icon {
    font-size: 0.85rem;
    opacity: var(--opacity-subtle);
  }

  .uptime-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
  }

  .uptime-value {
    margin-left: auto;
    font-size: 0.85rem;
    font-weight: 700;
    font-family: 'Courier New', monospace;
    color: var(--text-primary);
  }

  .auto-reduce-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 10px;
    background: var(--surface-subtle);
    border: 1px solid var(--surface-border);
    border-radius: 8px;
  }

  .auto-reduce-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
  }

  .force-low-fps-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 10px;
    background: rgba(239, 68, 68, 0.05);
    border: 1px dashed rgba(239, 68, 68, 0.25);
    border-radius: 8px;
  }

  .force-low-fps-label {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #f87171;
  }

  .auto-reduce-toggle {
    position: relative;
    width: 36px;
    height: 20px;
    border-radius: 10px;
    border: none;
    background: var(--border-color);
    cursor: pointer;
    padding: 0;
    transition: background 0.2s;
  }

  .auto-reduce-toggle.active {
    background: #22c55e;
  }

  .auto-reduce-knob {
    position: absolute;
    top: 3px;
    left: 3px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: white;
    transition: transform 0.2s;
  }

  .auto-reduce-toggle.active .auto-reduce-knob {
    transform: translateX(16px);
  }

  .status-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    background: var(--surface-subtle);
    border-radius: 8px;
    margin-top: auto;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--text-secondary);
    animation: pulse 2s ease-in-out infinite;
  }

  .status-text {
    font-size: 0.7rem;
    color: var(--text-secondary);
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: var(--opacity-pulse-min); }
  }
</style>
