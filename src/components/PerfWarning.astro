<!-- Performance detail popup (opened manually via FPS card click) -->
<div id="perf-warning" class="perf-overlay" hidden>
  <div class="perf-popup">
    <div class="perf-header">
      <span id="perf-icon" class="perf-icon">&#9888;</span>
      <span id="perf-title" class="perf-title">Performance</span>
      <button id="perf-close" class="perf-close" aria-label="Close">&times;</button>
    </div>
    <p id="perf-desc" class="perf-desc">
      The simulation is running at <strong id="perf-popup-fps">0</strong> FPS.
    </p>
  </div>
</div>

<script>
  import {
    $particleMetrics,
    $particleConfig,
    $isPaused,
    $autoReduceParticles,
  } from '../stores/store';

  const overlay = document.getElementById('perf-warning')!;
  const popupFps = document.getElementById('perf-popup-fps')!;
  const popupIcon = document.getElementById('perf-icon')!;
  const popupTitle = document.getElementById('perf-title')!;
  const popupDesc = document.getElementById('perf-desc')!;
  const btnClose = document.getElementById('perf-close')!;

  const AUTO_REDUCE_FPS_THRESHOLD = 45;
  const CRITICAL_FPS_THRESHOLD = 30;
  const AUTO_ENABLE_DELAY = 2000; // ms of sustained critical FPS before auto-enabling

  let lastSeenFps = -1;
  let popupOpen = false;
  let criticalSince: number | null = null; // timestamp when FPS first dropped below critical

  function updatePopupContent(fps: number) {
    popupFps.textContent = String(fps);

    if (fps >= 55) {
      popupIcon.textContent = '\u2714'; // checkmark
      popupIcon.style.color = '#22c55e';
      popupTitle.textContent = 'Performance is Good';
      popupDesc.innerHTML = `The simulation is running at <strong>${fps}</strong> FPS. Everything looks smooth.`;
    } else if (fps >= 30) {
      popupIcon.textContent = '\u26A0'; // warning
      popupIcon.style.color = '#f59e0b';
      popupTitle.textContent = 'Performance Could Be Better';
      popupDesc.innerHTML = `The simulation is running at <strong>${fps}</strong> FPS. It may feel slightly choppy.`;
    } else {
      popupIcon.textContent = '\u26A0'; // warning
      popupIcon.style.color = '#ef4444';
      popupTitle.textContent = 'Low Performance Detected';
      popupDesc.innerHTML = `The simulation is running at <strong>${fps}</strong> FPS. This may cause lag or high CPU usage.`;
    }
  }

  function showPopup() {
    popupOpen = true;
    updatePopupContent(lastSeenFps);
    overlay.hidden = false;
    requestAnimationFrame(() => overlay.classList.add('visible'));
  }

  function hidePopup() {
    overlay.classList.remove('visible');
    popupOpen = false;
    setTimeout(() => { overlay.hidden = true; }, 200);
  }

  // Expose globally so MetricsPanel can open it
  (window as any).__showPerfPopup = () => {
    lastSeenFps = $particleMetrics.get().fps;
    showPopup();
  };

  btnClose.addEventListener('click', () => hidePopup());

  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) hidePopup();
  });

  // --- Monitor FPS for auto-reduce ---

  $particleMetrics.subscribe((m) => {
    if (m.fps === 0) return;

    // Update popup content if it's open and FPS changed
    if (popupOpen && m.fps !== lastSeenFps) updatePopupContent(m.fps);
    lastSeenFps = m.fps;

    // Auto-enable auto-reduce after sustained critical FPS
    if (!$autoReduceParticles.get() && !$isPaused.get() && m.fps < CRITICAL_FPS_THRESHOLD) {
      if (criticalSince === null) {
        criticalSince = Date.now();
      } else if (Date.now() - criticalSince >= AUTO_ENABLE_DELAY) {
        $autoReduceParticles.set(true);
        criticalSince = null;
      }
    } else if (m.fps >= CRITICAL_FPS_THRESHOLD) {
      criticalSince = null;
    }

    // Auto-reduce silently if enabled
    if ($autoReduceParticles.get() && m.fps < AUTO_REDUCE_FPS_THRESHOLD && !$isPaused.get()) {
      const current = $particleConfig.get().count;
      if (current > 50) {
        $particleConfig.setKey('count', Math.max(50, Math.round(current * 0.8)));
      }
    }
  });
</script>

<style>
  /* --- Popup overlay --- */
  .perf-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0);
    backdrop-filter: blur(0px);
    transition: background 0.2s, backdrop-filter 0.2s;
  }

  .perf-overlay.visible {
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .perf-popup {
    background: var(--bg-panel);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 1.5rem;
    max-width: 360px;
    width: 90%;
    transform: scale(0.95);
    opacity: 0;
    transition: transform 0.2s ease-out, opacity 0.2s ease-out;
  }

  .perf-overlay.visible .perf-popup {
    transform: scale(1);
    opacity: 1;
  }

  .perf-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .perf-close {
    margin-left: auto;
    background: none;
    border: none;
    color: var(--text-secondary);
    font-size: 1.3rem;
    line-height: 1;
    cursor: pointer;
    padding: 2px 6px;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }

  .perf-close:hover {
    color: var(--text-primary);
    background: var(--surface-overlay-hover);
  }

  .perf-icon {
    font-size: 1.3rem;
    color: #f59e0b;
    transition: color 0.3s;
  }

  .perf-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .perf-desc {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }
</style>
