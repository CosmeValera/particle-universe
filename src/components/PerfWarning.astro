---
---

<!-- Floating pill — always shows current FPS once triggered -->
<button id="perf-pill" class="perf-pill" hidden>
  <span id="perf-pill-dot" class="perf-pill-dot"></span>
  <span id="perf-pill-label" class="perf-pill-text">FPS: <strong id="perf-pill-fps">0</strong></span>
</button>

<!-- Full popup overlay -->
<div id="perf-warning" class="perf-overlay" hidden>
  <div class="perf-popup">
    <div class="perf-header">
      <span id="perf-icon" class="perf-icon">&#9888;</span>
      <span id="perf-title" class="perf-title">Performance</span>
      <button id="perf-close" class="perf-close" aria-label="Close">&times;</button>
    </div>
    <p id="perf-desc" class="perf-desc">
      The simulation is running at <strong id="perf-popup-fps">0</strong> FPS.
    </p>
    <div id="perf-actions" class="perf-actions">
      <button id="perf-pause" class="perf-btn perf-btn-primary">
        Pause Simulation
      </button>
      <button id="perf-auto-reduce" class="perf-btn perf-btn-secondary">
        Auto-reduce Particles
      </button>
      <button id="perf-snooze" class="perf-btn perf-btn-ghost">
        Remind me in 5 minutes
      </button>
    </div>
  </div>
</div>

<script>
  import {
    $particleMetrics,
    $particleConfig,
    $isPaused,
    $autoReduceParticles,
    togglePause,
  } from '../stores/store';

  const pill = document.getElementById('perf-pill')!;
  const pillFps = document.getElementById('perf-pill-fps')!;
  const pillDot = document.getElementById('perf-pill-dot')!;
  const pillLabel = document.getElementById('perf-pill-label')!;
  const overlay = document.getElementById('perf-warning')!;
  const popupFps = document.getElementById('perf-popup-fps')!;
  const popupIcon = document.getElementById('perf-icon')!;
  const popupTitle = document.getElementById('perf-title')!;
  const popupDesc = document.getElementById('perf-desc')!;
  const btnPause = document.getElementById('perf-pause')!;
  const btnAutoReduce = document.getElementById('perf-auto-reduce')!;
  const btnSnooze = document.getElementById('perf-snooze')!;
  const btnClose = document.getElementById('perf-close')!;

  const LOW_FPS_THRESHOLD = 30;
  const AUTO_REDUCE_FPS_THRESHOLD = 45;
  const SUSTAINED_CHECKS = 4;
  const SNOOZE_MS = 5 * 60 * 1000;

  let lowFpsCount = 0;
  let lastSeenFps = -1;
  let popupOpen = false;
  let snoozedUntil = 0;
  let autoPopupShown = false;
  let pillVisible = false;

  // FPS tier: 'good' >= 55, 'ok' >= 30, 'bad' < 30
  type FpsTier = 'good' | 'ok' | 'bad';

  function getFpsTier(fps: number): FpsTier {
    if (fps >= 55) return 'good';
    if (fps >= 30) return 'ok';
    return 'bad';
  }

  const tierColors: Record<FpsTier, string> = {
    good: '#22c55e',
    ok: '#f59e0b',
    bad: '#ef4444',
  };

  const tierBorders: Record<FpsTier, string> = {
    good: 'rgba(34, 197, 94, 0.35)',
    ok: 'rgba(245, 158, 11, 0.35)',
    bad: 'rgba(239, 68, 68, 0.35)',
  };

  const tierBordersHover: Record<FpsTier, string> = {
    good: 'rgba(34, 197, 94, 0.6)',
    ok: 'rgba(245, 158, 11, 0.6)',
    bad: 'rgba(239, 68, 68, 0.6)',
  };

  function updatePillStyle(fps: number) {
    const tier = getFpsTier(fps);
    const color = tierColors[tier];
    pill.style.borderColor = tierBorders[tier];
    pill.style.color = color;
    pillDot.style.background = color;
    pillFps.textContent = String(fps);
  }

  function updatePopupContent(fps: number) {
    const tier = getFpsTier(fps);
    popupFps.textContent = String(fps);

    if (tier === 'good') {
      popupIcon.textContent = '\u2714'; // checkmark
      popupIcon.style.color = '#22c55e';
      popupTitle.textContent = 'Performance is Good';
      popupDesc.innerHTML = `The simulation is running at <strong>${fps}</strong> FPS. Everything looks smooth.`;
      btnPause.style.display = 'none';
      btnAutoReduce.textContent = 'Enable Auto-reduce (preventive)';
      btnSnooze.style.display = 'none';
    } else if (tier === 'ok') {
      popupIcon.textContent = '\u26A0'; // warning
      popupIcon.style.color = '#f59e0b';
      popupTitle.textContent = 'Performance Could Be Better';
      popupDesc.innerHTML = `The simulation is running at <strong>${fps}</strong> FPS. It may feel slightly choppy.`;
      btnPause.style.display = '';
      btnAutoReduce.textContent = 'Auto-reduce Particles';
      btnSnooze.style.display = '';
    } else {
      popupIcon.textContent = '\u26A0'; // warning
      popupIcon.style.color = '#ef4444';
      popupTitle.textContent = 'Low Performance Detected';
      popupDesc.innerHTML = `The simulation is running at <strong>${fps}</strong> FPS. This may cause lag or high CPU usage.`;
      btnPause.style.display = '';
      btnAutoReduce.textContent = 'Auto-reduce Particles';
      btnSnooze.style.display = '';
    }
  }

  function showPill() {
    if (pillVisible) return;
    pillVisible = true;
    pill.hidden = false;
    requestAnimationFrame(() => pill.classList.add('visible'));
  }

  function showPopup() {
    popupOpen = true;
    updatePopupContent(lastSeenFps);
    overlay.hidden = false;
    requestAnimationFrame(() => overlay.classList.add('visible'));
  }

  function hidePopup() {
    overlay.classList.remove('visible');
    popupOpen = false;
    lowFpsCount = 0;
    setTimeout(() => { overlay.hidden = true; }, 200);
  }

  // Clicking the pill opens the popup
  pill.addEventListener('click', () => {
    updatePopupContent(lastSeenFps);
    showPopup();
  });

  // Hover style adapts to current tier
  pill.addEventListener('mouseenter', () => {
    const tier = getFpsTier(lastSeenFps);
    pill.style.borderColor = tierBordersHover[tier];
  });
  pill.addEventListener('mouseleave', () => {
    const tier = getFpsTier(lastSeenFps);
    pill.style.borderColor = tierBorders[tier];
  });

  // --- Popup button handlers ---

  btnPause.addEventListener('click', () => {
    if (!$isPaused.get()) togglePause();
    autoPopupShown = false;
    lowFpsCount = 0;
    hidePopup();
  });

  btnAutoReduce.addEventListener('click', () => {
    $autoReduceParticles.set(true);
    const current = $particleConfig.get().count;
    $particleConfig.setKey('count', Math.max(50, Math.round(current * 0.6)));
    hidePopup();
  });

  btnSnooze.addEventListener('click', () => {
    snoozedUntil = Date.now() + SNOOZE_MS;
    hidePopup();
  });

  btnClose.addEventListener('click', () => {
    hidePopup();
  });

  // --- Monitor FPS ---

  $particleMetrics.subscribe((m) => {
    if (m.fps === lastSeenFps) return;
    lastSeenFps = m.fps;
    if (m.fps === 0) return;

    const isLow = m.fps < LOW_FPS_THRESHOLD;
    const snoozed = Date.now() < snoozedUntil;

    // Auto-reduce silently if enabled (triggers earlier at 45 FPS for smoother experience)
    if ($autoReduceParticles.get() && m.fps < AUTO_REDUCE_FPS_THRESHOLD && !$isPaused.get()) {
      const current = $particleConfig.get().count;
      if (current > 50) {
        $particleConfig.setKey('count', Math.max(50, Math.round(current * 0.8)));
      }
      return;
    }

    // Always keep the pill in sync
    if (pillVisible) {
      updatePillStyle(m.fps);
    }

    // Show the floating pill on first low FPS — it stays forever after that
    if (isLow && !$isPaused.get()) {
      updatePillStyle(m.fps);
      showPill();
    }

    // Auto-open popup once after sustained low FPS
    if (popupOpen || $isPaused.get() || snoozed) return;

    if (isLow) {
      lowFpsCount++;
      if (lowFpsCount >= SUSTAINED_CHECKS && !autoPopupShown) {
        autoPopupShown = true;
        showPopup();
      }
    } else {
      lowFpsCount = 0;
    }
  });
</script>

<style>
  /* --- Floating pill --- */
  .perf-pill {
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    z-index: 999;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: var(--bg-panel);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(245, 158, 11, 0.35);
    border-radius: 100px;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.75rem;
    color: #fbbf24;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.2s, transform 0.2s, border-color 0.3s, background 0.2s, color 0.3s;
  }

  .perf-pill.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .perf-pill:hover {
    background: var(--bg-panel-hover);
  }

  .perf-pill-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #f59e0b;
    transition: background 0.3s;
    animation: pill-pulse 1.5s ease-in-out infinite;
  }

  .perf-pill-text {
    letter-spacing: 0.02em;
  }

  @keyframes pill-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  /* --- Popup overlay --- */
  .perf-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0);
    backdrop-filter: blur(0px);
    transition: background 0.2s, backdrop-filter 0.2s;
  }

  .perf-overlay.visible {
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .perf-popup {
    background: var(--bg-panel);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 1.5rem;
    max-width: 360px;
    width: 90%;
    transform: scale(0.95);
    opacity: 0;
    transition: transform 0.2s ease-out, opacity 0.2s ease-out;
  }

  .perf-overlay.visible .perf-popup {
    transform: scale(1);
    opacity: 1;
  }

  .perf-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .perf-close {
    margin-left: auto;
    background: none;
    border: none;
    color: var(--text-secondary);
    font-size: 1.3rem;
    line-height: 1;
    cursor: pointer;
    padding: 2px 6px;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }

  .perf-close:hover {
    color: var(--text-primary);
    background: var(--surface-overlay-hover);
  }

  .perf-icon {
    font-size: 1.3rem;
    color: #f59e0b;
    transition: color 0.3s;
  }

  .perf-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .perf-desc {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0 0 1.25rem;
  }

  .perf-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .perf-btn {
    padding: 10px 14px;
    font-size: 0.78rem;
    font-weight: 600;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.15s;
    border: 1px solid transparent;
    font-family: inherit;
  }

  .perf-btn-primary {
    background: rgba(239, 68, 68, 0.15);
    border-color: rgba(239, 68, 68, 0.35);
    color: #f87171;
  }
  .perf-btn-primary:hover {
    background: rgba(239, 68, 68, 0.25);
  }

  .perf-btn-secondary {
    background: rgba(245, 158, 11, 0.12);
    border-color: rgba(245, 158, 11, 0.3);
    color: #fbbf24;
  }
  .perf-btn-secondary:hover {
    background: rgba(245, 158, 11, 0.22);
  }

  .perf-btn-ghost {
    background: var(--surface-overlay);
    border-color: var(--border-color);
    color: var(--text-secondary);
  }
  .perf-btn-ghost:hover {
    background: var(--surface-overlay-hover);
    color: var(--text-primary);
  }
</style>
