---
---

<!-- Performance detail popup (opened manually via FPS card click) -->
<div id="perf-warning" class="perf-overlay" hidden>
  <div class="perf-popup">
    <div class="perf-header">
      <span id="perf-icon" class="perf-icon">&#9888;</span>
      <span id="perf-title" class="perf-title">Performance</span>
      <button id="perf-close" class="perf-close" aria-label="Close">&times;</button>
    </div>
    <p id="perf-desc" class="perf-desc">
      The simulation is running at <strong id="perf-popup-fps">0</strong> FPS.
    </p>
  </div>
</div>

<!-- Toast notification for auto-reduce -->
<div id="perf-toast" class="perf-toast" hidden>
  <span id="perf-toast-icon" class="perf-toast-icon">&#9888;</span>
  <span id="perf-toast-text" class="perf-toast-text"></span>
  <button id="perf-toast-close" class="perf-toast-close" aria-label="Dismiss">&times;</button>
</div>

<script>
  import {
    $particleMetrics,
    $particleConfig,
    $isPaused,
    $autoReduceParticles,
  } from '../stores/store';

  const overlay = document.getElementById('perf-warning')!;
  const popupFps = document.getElementById('perf-popup-fps')!;
  const popupIcon = document.getElementById('perf-icon')!;
  const popupTitle = document.getElementById('perf-title')!;
  const popupDesc = document.getElementById('perf-desc')!;
  const btnClose = document.getElementById('perf-close')!;

  const AUTO_REDUCE_FPS_THRESHOLD = 45;
  const CRITICAL_FPS_THRESHOLD = 30;
  const REDUCE_COOLDOWN = 2000; // ms between reduction steps
  const RECOVER_COOLDOWN = 3000; // ms between recovery steps
  const RECOVER_FPS_THRESHOLD = 55; // FPS must be above this to recover
  const REDUCE_FACTOR = 0.85; // keep 85% each step (gentle 15% reduction)
  const RECOVER_FACTOR = 1.10; // recover 10% each step
  const SUGGEST_DELAY = 4000; // ms of sustained low FPS before suggesting auto-reduce

  let lastSeenFps = -1;
  let popupOpen = false;
  let lastReduceTime = 0;
  let lastRecoverTime = 0;
  let originalCount: number | null = null; // remember count before reductions started
  let lowFpsSince: number | null = null; // for toast suggestion
  let toastShownThisSession = false;
  let toastTimeout: ReturnType<typeof setTimeout> | null = null;

  // Toast elements
  const toast = document.getElementById('perf-toast')!;
  const toastText = document.getElementById('perf-toast-text')!;
  const toastIcon = document.getElementById('perf-toast-icon')!;
  const toastClose = document.getElementById('perf-toast-close')!;

  function showToast(message: string, icon = '\u26A0', duration = 5000) {
    toastText.textContent = message;
    toastIcon.textContent = icon;
    toast.hidden = false;
    requestAnimationFrame(() => toast.classList.add('visible'));

    if (toastTimeout) clearTimeout(toastTimeout);
    toastTimeout = setTimeout(hideToast, duration);
  }

  function hideToast() {
    toast.classList.remove('visible');
    if (toastTimeout) { clearTimeout(toastTimeout); toastTimeout = null; }
    setTimeout(() => { toast.hidden = true; }, 300);
  }

  toastClose.addEventListener('click', hideToast);

  function getMinFloor() {
    // Floor is 20% of original count, but at least 100
    if (originalCount !== null) {
      return Math.max(100, Math.round(originalCount * 0.2));
    }
    return 100;
  }

  function updatePopupContent(fps: number) {
    popupFps.textContent = String(fps);

    if (fps >= 55) {
      popupIcon.textContent = '\u2714'; // checkmark
      popupIcon.style.color = '#22c55e';
      popupTitle.textContent = 'Performance is Good';
      popupDesc.innerHTML = `The simulation is running at <strong>${fps}</strong> FPS. Everything looks smooth.`;
    } else if (fps >= 30) {
      popupIcon.textContent = '\u26A0'; // warning
      popupIcon.style.color = '#f59e0b';
      popupTitle.textContent = 'Performance Could Be Better';
      popupDesc.innerHTML = `The simulation is running at <strong>${fps}</strong> FPS. It may feel slightly choppy.`;
    } else {
      popupIcon.textContent = '\u26A0'; // warning
      popupIcon.style.color = '#ef4444';
      popupTitle.textContent = 'Low Performance Detected';
      popupDesc.innerHTML = `The simulation is running at <strong>${fps}</strong> FPS. This may cause lag or high CPU usage.`;
    }
  }

  function showPopup() {
    popupOpen = true;
    updatePopupContent(lastSeenFps);
    overlay.hidden = false;
    requestAnimationFrame(() => overlay.classList.add('visible'));
  }

  function hidePopup() {
    overlay.classList.remove('visible');
    popupOpen = false;
    setTimeout(() => { overlay.hidden = true; }, 200);
  }

  // Expose globally so MetricsPanel can open it
  (window as any).__showPerfPopup = () => {
    lastSeenFps = $particleMetrics.get().fps;
    showPopup();
  };

  btnClose.addEventListener('click', () => hidePopup());

  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) hidePopup();
  });

  // --- Monitor FPS for auto-reduce ---

  $particleMetrics.subscribe((m) => {
    if (m.fps === 0) return;

    // Update popup content if it's open and FPS changed
    if (popupOpen && m.fps !== lastSeenFps) updatePopupContent(m.fps);
    lastSeenFps = m.fps;

    const now = Date.now();
    const isPaused = $isPaused.get();
    const autoReduceOn = $autoReduceParticles.get();

    // Suggest auto-reduce via toast (don't auto-enable it)
    if (!autoReduceOn && !isPaused && m.fps < CRITICAL_FPS_THRESHOLD) {
      if (lowFpsSince === null) {
        lowFpsSince = now;
      } else if (!toastShownThisSession && now - lowFpsSince >= SUGGEST_DELAY) {
        showToast('Performance is low. Try enabling auto-adjust in the Metrics panel.', '\u26A0', 6000);
        toastShownThisSession = true;
      }
    } else if (m.fps >= CRITICAL_FPS_THRESHOLD) {
      lowFpsSince = null;
    }

    // Gradual reduction with cooldown
    if (autoReduceOn && m.fps < AUTO_REDUCE_FPS_THRESHOLD && !isPaused) {
      const current = $particleConfig.get().count;
      const floor = getMinFloor();

      // Remember original count when reductions start
      if (originalCount === null) {
        originalCount = current;
      }

      if (current > floor && now - lastReduceTime >= REDUCE_COOLDOWN) {
        const newCount = Math.max(floor, Math.round(current * REDUCE_FACTOR));
        if (newCount < current) {
          $particleConfig.setKey('count', newCount);
          lastReduceTime = now;
        }
      }
    }

    // Gradual recovery: when FPS is good, step particles back up toward original
    if (autoReduceOn && m.fps >= RECOVER_FPS_THRESHOLD && !isPaused && originalCount !== null) {
      const current = $particleConfig.get().count;
      if (current < originalCount && now - lastRecoverTime >= RECOVER_COOLDOWN) {
        const newCount = Math.min(originalCount, Math.round(current * RECOVER_FACTOR));
        if (newCount > current) {
          $particleConfig.setKey('count', newCount);
          lastRecoverTime = now;
          // Reset reduce timer so we don't immediately reduce what we just recovered
          lastReduceTime = now;
        }
      }
    }
  });

  // Reset original count tracking when auto-reduce is toggled off
  $autoReduceParticles.subscribe((on) => {
    if (!on) {
      originalCount = null;
    }
  });
</script>

<style>
  /* --- Popup overlay --- */
  .perf-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0);
    backdrop-filter: blur(0px);
    transition: background 0.2s, backdrop-filter 0.2s;
  }

  .perf-overlay.visible {
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .perf-popup {
    background: var(--bg-panel);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 1.5rem;
    max-width: 360px;
    width: 90%;
    transform: scale(0.95);
    opacity: 0;
    transition: transform 0.2s ease-out, opacity 0.2s ease-out;
  }

  .perf-overlay.visible .perf-popup {
    transform: scale(1);
    opacity: 1;
  }

  .perf-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .perf-close {
    margin-left: auto;
    background: none;
    border: none;
    color: var(--text-secondary);
    font-size: 1.3rem;
    line-height: 1;
    cursor: pointer;
    padding: 2px 6px;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }

  .perf-close:hover {
    color: var(--text-primary);
    background: var(--surface-overlay-hover);
  }

  .perf-icon {
    font-size: 1.3rem;
    color: #f59e0b;
    transition: color 0.3s;
  }

  .perf-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .perf-desc {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  /* --- Toast notification --- */
  .perf-toast {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    z-index: 999;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1rem;
    background: var(--bg-panel);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    opacity: 0;
    transition: opacity 0.3s, transform 0.3s;
    max-width: 420px;
  }

  .perf-toast.visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .perf-toast-icon {
    font-size: 1rem;
    color: #f59e0b;
    flex-shrink: 0;
  }

  .perf-toast-text {
    font-size: 0.75rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .perf-toast-close {
    background: none;
    border: none;
    color: var(--text-secondary);
    font-size: 1rem;
    cursor: pointer;
    padding: 0 2px;
    margin-left: 0.25rem;
    flex-shrink: 0;
    border-radius: 4px;
    transition: color 0.15s;
  }

  .perf-toast-close:hover {
    color: var(--text-primary);
  }
</style>
