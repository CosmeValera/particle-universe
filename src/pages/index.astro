---
import Layout from '../layouts/Layout.astro';
import ControlPanel from '../components/vue/ControlPanel.vue';
import ParticleCanvas from '../components/react/ParticleCanvas';
import MetricsPanel from '../components/MetricsPanel.astro';
import PerfWarning from '../components/PerfWarning.astro';
import '../styles/global.css';
---

<Layout title="Particle Universe | Multi-Framework Dashboard">
  <div class="dashboard-grid">
    <!-- Vue Panel: Controls -->
    <section class="panel panel-vue controls-panel">
      <ControlPanel client:load />
    </section>

    <!-- React Panel: Particle Canvas -->
    <section class="panel panel-react canvas-panel canvas-glow">
      <div class="canvas-header">
        <span class="framework-badge badge-react">
          <svg width="12" height="12" viewBox="0 0 256 228">
            <circle cx="128" cy="114" r="20" fill="#61DAFB"/>
            <ellipse cx="128" cy="114" rx="115" ry="44" fill="none" stroke="#61DAFB" stroke-width="8"/>
            <ellipse cx="128" cy="114" rx="115" ry="44" fill="none" stroke="#61DAFB" stroke-width="8" transform="rotate(60 128 114)"/>
            <ellipse cx="128" cy="114" rx="115" ry="44" fill="none" stroke="#61DAFB" stroke-width="8" transform="rotate(120 128 114)"/>
          </svg>
          React Canvas
        </span>
        <span class="canvas-hint">Click & drag to attract particles</span>
      </div>
      <div class="canvas-wrapper">
        <ParticleCanvas client:load />
      </div>
    </section>

    <!-- Metrics Panel -->
    <section class="panel panel-angular metrics-panel">
      <MetricsPanel />
    </section>
  </div>

  <footer class="footer">
    <p>
      Built with
      <span class="footer-tech">Astro</span> +
      <span class="footer-tech vue">Vue</span> +
      <span class="footer-tech react">React</span> +
      <span class="footer-tech angular">Angular</span>, state shared via <span class="footer-tech">nanostores</span>
    </p>
  </footer>

  <PerfWarning />
</Layout>

<style>
  .dashboard-grid {
    display: grid;
    grid-template-columns: 280px 1fr 220px;
    gap: 1rem;
    flex: 1;
    min-height: 0;
  }

  .controls-panel {
    overflow-y: auto;
  }

  .canvas-panel {
    display: flex;
    flex-direction: column;
    padding: 0.75rem;
  }

  .canvas-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 0.5rem 0.5rem;
  }

  .canvas-hint {
    font-size: 0.65rem;
    color: var(--text-secondary);
    opacity: var(--opacity-subtle);
  }

  .canvas-wrapper {
    flex: 1;
    min-height: 0;
    border-radius: 8px;
    overflow: hidden;
  }

  .metrics-panel {
    overflow-y: auto;
  }

  .footer {
    text-align: center;
    padding: 0.5rem 1rem;
    color: var(--text-secondary);
    font-size: 0.7rem;
    flex-shrink: 0;
  }

  .footer p {
    margin: 0;
  }

  .footer-tech {
    font-weight: 600;
    color: var(--text-primary);
  }

  .footer-tech.vue { color: var(--accent-vue); }
  .footer-tech.react { color: var(--accent-react); }
  .footer-tech.angular { color: var(--accent-angular); }

  @media (max-width: 1024px) {
    .dashboard-grid {
      grid-template-columns: 1fr;
      flex: none;
    }

    .canvas-panel {
      height: 60vh;
      min-height: 400px;
    }

    .controls-panel {
      order: -1;
    }
  }

  @media (max-width: 768px) {
    .canvas-panel {
      height: 50vh;
      min-height: 300px;
    }
  }
</style>
